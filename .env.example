# ═══════════════════════════════════════════
#  TikTok Song Request — Environment Config
#  Salin file ini ke .env dan isi nilainya
# ═══════════════════════════════════════════

# ── WAJIB ─────────────────────────────────
# Username TikTok yang akan dimonitor (TANPA @)
TIKTOK_USERNAME=your_tiktok_username

# ── OPSIONAL ──────────────────────────────
# YouTube Data API v3 Key (untuk thumbnail & pencarian akurat)
# Dapatkan di: https://console.cloud.google.com/
# Tanpa key ini, overlay tetap tampil tapi tanpa thumbnail
YOUTUBE_API_KEY=your_youtube_api_key_here

# Prefix command untuk request lagu (default: !req)
REQUEST_PREFIX=!req

# Maksimal lagu dalam antrian (default: 50)
MAX_QUEUE_SIZE=50

# ── SERVER ────────────────────────────────
# Port server (Railway/Render otomatis mengisi ini)
PORT=3000

# Environment: development | production
NODE_ENV=development

# ── PRODUCTION ────────────────────────────
# CORS origins yang diizinkan (pisahkan dengan koma)
# Gunakan * untuk semua origin (tidak disarankan di production)
# Contoh: https://my-app.railway.app,https://my-other-domain.com
ALLOWED_ORIGINS=*

# Aktifkan simulator di production (default: false)
# Set ke true jika ingin testing di server live
ENABLE_SIMULATOR=false
